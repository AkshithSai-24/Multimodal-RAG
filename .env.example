# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# LLM model slug — any OpenRouter-supported model
# See https://openrouter.ai/models
LLM_MODEL=anthropic/claude-3.5-sonnet
VISION_MODEL=anthropic/claude-3.5-sonnet

# App meta (sent to OpenRouter in request headers)
APP_SITE_URL=http://localhost:8000
APP_NAME=MultiModal-RAG

# ── Google Generative AI (Embeddings) ─────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Required scopes: none (API key is sufficient)
GOOGLE_API_KEY=your-google-api-key-here

# Gemini embedding model
# Latest recommended: models/text-embedding-004  (768-dim, best quality)
# Alternative:        models/embedding-001        (768-dim, older)
# Full list: https://ai.google.dev/gemini-api/docs/models/gemini#text-embedding
EMBEDDING_MODEL=models/text-embedding-004

# Embedding task type — controls how the model optimises the vectors
# retrieval_document  → use when ingesting documents  (default)
# retrieval_query     → use when embedding a search query
# semantic_similarity → use for similarity comparisons
# classification      → use for classification tasks
# clustering          → use for clustering tasks
EMBEDDING_TASK_TYPE=retrieval_document

# ── Chroma ────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=multimodal_rag

# ── Google Drive MCP ─────────────────────────────────────────────────────────
# OAuth2 access token — obtain via Google Cloud OAuth2 flow
# Scopes needed: https://www.googleapis.com/auth/drive.readonly
GDRIVE_MCP_URL=https://drivemcp.googleapis.com/mcp/v1
GDRIVE_ACCESS_TOKEN=

# ── FastAPI ───────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=6
MAX_IMAGE_DOCS=3
INCLUDE_IMAGES_IN_RESPONSE=true
